# Production Environment Variables Template
# Copy this to Netlify Dashboard or create appropriate .env files

# Backend API URL - IMPORTANT: Replace with your deployed backend URL
# Examples:
# REACT_APP_API_BASE_URL=https://your-app.herokuapp.com
# REACT_APP_API_BASE_URL=https://your-backend-api.railway.app
# REACT_APP_API_BASE_URL=https://api.yourdomain.com
REACT_APP_API_BASE_URL=https://your-backend-api-url-here.com
